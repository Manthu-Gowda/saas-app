MONGO_URI=mongodb://localhost:27017/zynapse
PORT=5000
JWT_SECRET=df65eaecc1214a1f19388aba759a4287a8386af2a08a61c5193593a52feda07f62e0c91a986b09a18222fa94659d117bc594b1ea9188b7d5ef16022e8bca7c16

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Create products + prices in Stripe Dashboard, then paste the Price IDs below
STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_BUSINESS=price_YOUR_BUSINESS_PRICE_ID

# Frontend URL (used in Stripe redirect URLs)
FRONTEND_URL=http://localhost:3000

# ─── AI Cost & Cache ───────────────────────────────────────────────────────────
USD_TO_INR=84
CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# ─── RAG / Embeddings ─────────────────────────────────────────────────────────
# Uses OpenAI embedding API — requires an active OpenAI provider in Admin → AI Providers
# Options: text-embedding-3-small (1536 dims, cheap) | text-embedding-3-large (3072 dims, accurate)
EMBEDDING_MODEL=text-embedding-3-small

# ─── Email (nodemailer SMTP) ───────────────────────────────────────────────────
# For Gmail: use App Password (https://myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Zynapse <your-email@gmail.com>
